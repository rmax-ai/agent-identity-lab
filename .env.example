# Agent Identity Lab — Environment Variables
# Copy to .env and fill in values

# PostgreSQL
POSTGRES_USER=ail
POSTGRES_PASSWORD=ail_dev
POSTGRES_DB=agent_identity_lab
DATABASE_URL=postgresql+asyncpg://ail:ail_dev@localhost:5432/agent_identity_lab

# Identity API
IDENTITY_API_PORT=8000
IDENTITY_API_SECRET=change-me-in-production

# Token Broker
TOKEN_BROKER_PORT=8001
TOKEN_BROKER_SECRET=change-me-in-production

# MCP Gateway
MCP_GATEWAY_PORT=8002

# Mock MCP Server
MOCK_MCP_PORT=8003

# Admin UI
NEXT_PUBLIC_API_URL=http://localhost:8000

# OPA
OPA_URL=http://localhost:8181

# Token Signing (generate with: openssl genpkey -algorithm RSA -out private.pem)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Logging
LOG_LEVEL=DEBUG
